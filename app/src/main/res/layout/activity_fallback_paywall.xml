<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/paywall_background">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="190dp"
        android:layout_gravity="bottom"
        android:alpha="0.8"
        android:contentDescription="@null"
        android:scaleType="fitXY"
        android:src="@drawable/paywall_equalizer" />

    <ImageView
        android:layout_width="230dp"
        android:layout_height="230dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="52dp"
        android:layout_marginEnd="-34dp"
        android:alpha="0.9"
        android:contentDescription="@null"
        android:src="@drawable/paywall_headphones" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="18dp"
            android:paddingEnd="22dp"
            android:paddingBottom="24dp">

            <Button
                android:id="@+id/fallback_paywall_close"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end"
                android:background="@drawable/paywall_close_button"
                android:elevation="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="x"
                android:textAllCaps="false"
                android:textColor="#CCFFFFFF"
                android:textSize="22sp" />

            <FrameLayout
                android:layout_width="112dp"
                android:layout_height="112dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/paywall_logo_ring"
                android:padding="18dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/app_name"
                    android:src="@mipmap/ic_launcher_foreground" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:includeFontPadding="false"
                android:text="ReClip Pro"
                android:textColor="#FFFFFFFF"
                android:textSize="42sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"
                android:text="Download, convert, and keep your media toolkit unlocked for life."
                android:textColor="#C8FFFFFF"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/paywall_feature_chip"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp"
                    android:text="- Spotify link support"
                    android:textColor="#FFFFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/paywall_feature_chip"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp"
                    android:text="- MP3 audio extraction"
                    android:textColor="#FFFFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/paywall_feature_chip"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp"
                    android:text="- Highest-quality downloads"
                    android:textColor="#FFFFFFFF"
                    android:textSize="15sp" />
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="@drawable/paywall_panel"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/fallback_paywall_price"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="$69.99 lifetime"
                    android:textColor="#FFFFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:text="One-time purchase. No subscription."
                    android:textColor="#B8FFFFFF"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/fallback_paywall_continue"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/paywall_primary_button"
                    android:elevation="0dp"
                    android:text="Unlock for $69.99"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/fallback_paywall_restore"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/paywall_secondary_button"
                    android:elevation="0dp"
                    android:text="Restore purchases"
                    android:textAllCaps="false"
                    android:textColor="#D8FFFFFF"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
