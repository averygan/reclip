<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070818"
    android:orientation="vertical"
    android:padding="24dp">

    <Button
        android:id="@+id/fallback_paywall_close"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="end"
        android:background="@android:color/transparent"
        android:text="✕"
        android:textColor="#B0B0C0"
        android:textSize="20sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="48dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ReClip Pro"
        android:textColor="#FFFFFF"
        android:textSize="40sp"
        android:textStyle="italic" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Unlock the full toolkit."
        android:textColor="#B0B0C0"
        android:textSize="15sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:lineSpacingExtra="10dp"
        android:text="·  Audio extraction (MP3)\n·  Highest-quality downloads\n·  Future Pro features"
        android:textColor="#FFFFFF"
        android:textSize="15sp" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/fallback_paywall_price"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:gravity="center"
        android:text="Unlock ReClip Pro"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/fallback_paywall_continue"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#E71885"
        android:text="Continue"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

    <Button
        android:id="@+id/fallback_paywall_restore"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:text="Restore Purchases"
        android:textAllCaps="false"
        android:textColor="#B0B0C0"
        android:textSize="14sp" />

</LinearLayout>
