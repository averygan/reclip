<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/paywall_background">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.78"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/paywall_neon_background" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/paywall_scrim" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="18dp"
            android:paddingEnd="22dp"
            android:paddingBottom="24dp">

            <Button
                android:id="@+id/reclip_paywall_close"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end"
                android:background="@drawable/paywall_close_button"
                android:elevation="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="x"
                android:textAllCaps="false"
                android:textColor="#DFFFFFFF"
                android:textSize="22sp" />

            <FrameLayout
                android:layout_width="128dp"
                android:layout_height="128dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:background="@drawable/paywall_logo_ring"
                android:padding="8dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/app_name"
                    android:scaleType="fitCenter"
                    android:src="@drawable/paywall_logo" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:includeFontPadding="false"
                android:letterSpacing="0.08"
                android:shadowColor="#D900E7FF"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="12"
                android:text="RECLIP"
                android:textColor="#FF8EFBFF"
                android:textSize="42sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:shadowColor="#D9FF2BC2"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="12"
                android:text="Unlock Premium"
                android:textColor="#FFFF7BE2"
                android:textSize="30sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="Download, convert, and keep your media toolkit glowing."
                android:textColor="#D8FFFFFF"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/paywall_feature_chip"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp"
                    android:text="Spotify link support"
                    android:textColor="#FFFFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/paywall_feature_chip"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp"
                    android:text="MP3 audio extraction"
                    android:textColor="#FFFFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/paywall_feature_chip"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp"
                    android:text="Highest-quality downloads"
                    android:textColor="#FFFFFFFF"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/paywall_panel"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/reclip_paywall_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Loading premium options..."
                    android:textColor="#D8FFFFFF"
                    android:textSize="15sp" />

                <LinearLayout
                    android:id="@+id/reclip_paywall_packages"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />

                <Button
                    android:id="@+id/reclip_paywall_continue"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/paywall_primary_button"
                    android:elevation="0dp"
                    android:enabled="false"
                    android:text="Unlock Premium"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/reclip_paywall_restore"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/paywall_secondary_button"
                    android:elevation="0dp"
                    android:text="Restore purchases"
                    android:textAllCaps="false"
                    android:textColor="#D8FFFFFF"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
