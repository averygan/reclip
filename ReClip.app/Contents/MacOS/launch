#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
if [ -f "$SCRIPT_DIR/native.py" ]; then
    APP_DIR="$SCRIPT_DIR"
elif [ -f "$HOME/.reclip/native.py" ]; then
    APP_DIR="$HOME/.reclip"
else
    osascript -e 'display dialog "ReClip files were not found.\n\nRun the installer again or launch from the project folder." buttons {"OK"} default button 1 with title "ReClip" with icon stop'
    exit 1
fi

PORT="${PORT:-8899}"
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

if ! command -v python3 &>/dev/null; then
    osascript -e 'display dialog "Python 3 was not found.\n\nInstall it with: brew install python3" buttons {"OK"} default button 1 with title "ReClip" with icon stop'
    exit 1
fi

if ! command -v ffmpeg &>/dev/null; then
    osascript -e 'display dialog "ffmpeg was not found.\n\nInstall it with: brew install ffmpeg" buttons {"OK"} default button 1 with title "ReClip" with icon stop'
    exit 1
fi

cd "$APP_DIR"
if [ ! -d "venv" ]; then
    python3 -m venv venv
fi

source venv/bin/activate
pip install -q -r requirements.txt

export PATH="$APP_DIR/venv/bin:$PATH"
export PORT

exec python3 "$APP_DIR/native.py"
